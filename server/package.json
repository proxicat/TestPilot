{
  "name": "testpilot-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "setup:wallet": "node scripts/setup-wallet.mjs",
    "gen:wallet": "node scripts/gen-wallet.mjs",
    "chain": "anvil --mnemonic \"$(cat .wallets/seed.txt)\" --chain-id 31337 --host 127.0.0.1 --port 8545",
    "fork": "anvil --fork-url \"$(cat .wallets/mainnet-rpc.txt)\" --chain-id 1 --mnemonic \"$(cat .wallets/seed.txt)\" --host 127.0.0.1 --port 8545",
    "proxy": "node scripts/model-proxy.mjs",
    "setup:onboard": "node scripts/onboard-wallet.mjs",
    "test:localtx": "node scripts/test-localtx.mjs",
    "test:sepolia": "node scripts/test-sepolia.mjs",
    "test:wrap": "node scripts/test-wrap.mjs",
    "test:fork-swap": "node scripts/test-fork-swap.mjs",
    "test:fork-router": "node scripts/test-fork-router-swap.mjs",
    "test:uniswap": "node scripts/test-uniswap.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midscene/web": "^0.30.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.17.0",
    "express": "^4.21.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^23.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer",
      "esbuild",
      "better-sqlite3"
    ]
  }
}